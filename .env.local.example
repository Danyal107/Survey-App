# MongoDB connection string (local or Atlas)
MONGODB_URI=mongodb://127.0.0.1:27017/survey-app

# Vercel Blob (server-side uploads from /api/upload/shop-image)
# The store must allow *public* blobs (not a private-only store), so image URLs work in the survey UI.
# Create/link a store in Vercel → Storage, then: `vercel env pull` or paste the read/write token here.
BLOB_READ_WRITE_TOKEN=
